```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out
dist/
build/
target/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo
*.bak
*.~*
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
*.min.js
*.min.css
bundle.js
```